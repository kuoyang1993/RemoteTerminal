<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/maven-v4_0_0.xsd">
  <modelVersion>4.0.0</modelVersion>
  <groupId>com.remoteterminal</groupId>
  <artifactId>RemoteTerminal</artifactId>
  <name>RemoteTerminal</name>
  <version>1.0.0</version>
  <build>
    <plugins>
      <plugin>
        <artifactId>maven-compiler-plugin</artifactId>
        <version>3.13.0</version>
        <configuration>
          <release>17</release>
        </configuration>
      </plugin>
      <plugin>
        <groupId>org.openjfx</groupId>
        <artifactId>javafx-maven-plugin</artifactId>
        <version>0.0.8</version>
        <configuration>
          <mainClass>${main.class}</mainClass>
        </configuration>
      </plugin>
      <plugin>
        <artifactId>maven-shade-plugin</artifactId>
        <version>3.6.0</version>
        <executions>
          <execution>
            <phase>package</phase>
            <goals>
              <goal>shade</goal>
            </goals>
            <configuration>
              <transformers>
                <transformer>
                  <mainClass>${main.class}</mainClass>
                </transformer>
              </transformers>
            </configuration>
          </execution>
        </executions>
      </plugin>
      <plugin>
        <groupId>org.panteleyev</groupId>
        <artifactId>jpackage-maven-plugin</artifactId>
        <version>1.6.3</version>
        <configuration>
          <name>RemoteTerminal</name>
          <appVersion>1.0.0</appVersion>
          <vendor>RemoteTerminal</vendor>
          <destination>target/dist</destination>
          <input>target</input>
          <mainJar>${project.build.finalName}.jar</mainJar>
          <mainClass>${main.class}</mainClass>
          <type>msi</type>
          <icon>ssh.ico</icon>
          <modulePath>lib/javafx-sdk-${javafx.version}/lib</modulePath>
          <addModules>javafx.controls,javafx.web,javafx.base,javafx.graphics,javafx.fxml</addModules>
          <winConsole>false</winConsole>
          <winDirChooser>true</winDirChooser>
          <winMenu>true</winMenu>
          <winShortcut>true</winShortcut>
          <winMenuGroup>RemoteTerminal</winMenuGroup>
        </configuration>
      </plugin>
    </plugins>
  </build>
  <properties>
    <maven.compiler.release>17</maven.compiler.release>
    <hikaricp.version>6.2.1</hikaricp.version>
    <main.class>com.remoteterminal.Main</main.class>
    <h2.version>2.3.232</h2.version>
    <jsch.version>0.2.23</jsch.version>
    <slf4j.version>2.0.17</slf4j.version>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    <javafx.version>17.0.14</javafx.version>
    <controlsfx.version>11.2.1</controlsfx.version>
  </properties>
</project>
